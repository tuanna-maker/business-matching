// ============================================
// TRUST SCORING & VOUCH MODELS - Epic 2
// ============================================

model TrustScore {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  org_id          String   @unique @db.Uuid
  score           Float    @default(0) // Final trust score (0-100)
  profile_score   Float    @default(0) // P: Profile completeness (0-100)
  iec_score       Float    @default(0) // I: IEC level score (0-100)
  vouch_score     Float    @default(0) // V: Vouching score (0-100)
  audit_score     Float    @default(0) // A: Audit history score (0-100)
  last_calculated DateTime @default(now()) @db.Timestamptz(6)
  created_at      DateTime @default(now()) @db.Timestamptz(6)
  updated_at      DateTime @default(now()) @db.Timestamptz(6)

  org Org @relation(fields: [org_id], references: [id])

  @@index([org_id], map: "idx_TrustScore_org_id")
  @@index([score], map: "idx_TrustScore_score")
  @@map("TrustScore")
}

model Vouch {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vouching_org_id String   @db.Uuid
  vouched_org_id  String   @db.Uuid
  vouch_type      String // "partnership", "transaction", "reference"
  notes           String?
  status          String   @default("active") // "active", "inactive", "revoked"
  created_at      DateTime @default(now()) @db.Timestamptz(6)
  updated_at      DateTime @default(now()) @db.Timestamptz(6)

  vouchingOrg Org @relation("VouchingOrg", fields: [vouching_org_id], references: [id])
  vouchedOrg  Org @relation("VouchedOrg", fields: [vouched_org_id], references: [id])

  @@unique([vouching_org_id, vouched_org_id])
  @@index([vouched_org_id], map: "idx_Vouch_vouched_org_id")
  @@index([vouching_org_id], map: "idx_Vouch_vouching_org_id")
  @@index([status], map: "idx_Vouch_status")
  @@map("Vouch")
}

// ============================================
// Webhook Integration for External Systems
// ============================================

model Webhook {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  org_id      String   @db.Uuid
  name        String
  url         String
  secret      String? // For HMAC signature verification
  events      String[] // Array of event types: ["dataroom_request", "iec_updated", "match_created", etc.]
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @default(now()) @db.Timestamptz(6)
  created_by  String?  @db.Uuid

  org        Org               @relation(fields: [org_id], references: [id])
  user       User?             @relation(fields: [created_by], references: [id])
  deliveries WebhookDelivery[]

  @@index([org_id], map: "idx_Webhook_org_id")
  @@index([is_active], map: "idx_Webhook_is_active")
  @@map("Webhook")
}

model WebhookDelivery {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  webhook_id      String   @db.Uuid
  event_type      String
  payload         Json
  response_status Int?
  response_body   String?
  attempts        Int      @default(1)
  status          String   @default("pending") // "pending", "success", "failed"
  delivered_at    DateTime? @db.Timestamptz(6)
  created_at      DateTime @default(now()) @db.Timestamptz(6)

  webhook Webhook @relation(fields: [webhook_id], references: [id])

  @@index([webhook_id], map: "idx_WebhookDelivery_webhook_id")
  @@index([status], map: "idx_WebhookDelivery_status")
  @@map("WebhookDelivery")
}

// ============================================
// Social Layer - Follow/Share/Activity
// ============================================

model OrgFollow {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  follower_id  String   @db.Uuid  // User who is following
  followed_id  String   @db.Uuid  // Org being followed
  created_at   DateTime @default(now()) @db.Timestamptz(6)

  follower User @relation("UserFollows", fields: [follower_id], references: [id])
  followed Org  @relation("OrgFollowers", fields: [followed_id], references: [id])

  @@unique([follower_id, followed_id])
  @@index([follower_id], map: "idx_OrgFollow_follower_id")
  @@index([followed_id], map: "idx_OrgFollow_followed_id")
  @@map("OrgFollow")
}

model Share {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String   @db.Uuid
  entity_type String   // "project", "org", "service"
  entity_id   String   @db.Uuid
  platform    String   // "linkedin", "twitter", "facebook", "email", "copy_link"
  created_at  DateTime @default(now()) @db.Timestamptz(6)

  user User @relation(fields: [user_id], references: [id])

  @@index([user_id], map: "idx_Share_user_id")
  @@index([entity_type, entity_id], map: "idx_Share_entity")
  @@map("Share")
}

model ActivityFeedItem {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  org_id       String   @db.Uuid
  actor_id     String?  @db.Uuid  // User who performed action (null for system events)
  activity_type String  // "project_created", "iec_updated", "milestone_reached", "funding_received", "team_joined", etc.
  entity_type  String?  // "project", "match", "team_member", etc.
  entity_id    String?  @db.Uuid
  title        String
  description  String?
  metadata     Json?    // Additional structured data
  is_public    Boolean  @default(true)
  created_at   DateTime @default(now()) @db.Timestamptz(6)

  org   Org   @relation(fields: [org_id], references: [id])
  actor User? @relation(fields: [actor_id], references: [id])

  @@index([org_id, is_public], map: "idx_ActivityFeedItem_org_public")
  @@index([org_id, created_at], map: "idx_ActivityFeedItem_org_created")
  @@index([activity_type], map: "idx_ActivityFeedItem_type")
  @@map("ActivityFeedItem")
}
