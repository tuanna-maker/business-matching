{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "prisma generate && NODE_ENV=development ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "tsc -p tsconfig.json",
    "build:shared": "tsc -p tsconfig.shared.json",
    "start": "node dist/main.js",
    "db:seed": "prisma db seed",
    "db:seed:full": "node prisma/seed-full.cjs",
    "db:seed:e2e-actors": "node prisma/seed-e2e-actors.cjs",
    "db:seed:realistic": "npx ts-node -r tsconfig-paths/register src/seed-realistic.ts"
  },
  "dependencies": {
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-socket.io": "^11.1.15",
    "@nestjs/websockets": "^11.1.15",
    "@prisma/client": "^6.19.2",
    "@types/uuid": "^11.0.0",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "socket.io": "^4.8.3",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/passport-jwt": "^4.0.1",
    "prisma": "^6.19.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0"
  },
  "prisma": {
    "seed": "node prisma/seed.cjs"
  }
}