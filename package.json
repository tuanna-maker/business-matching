{
  "name": "iec-hub-business-matching-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev:api": "pnpm --filter api dev",
    "dev:web": "pnpm --filter iec-hub-v4 dev",
    "dev:mobile": "pnpm --filter mobile start",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "test:api": "node scripts/auto-test.cjs",
    "test:e2e": "pnpm --filter iec-hub-v4 test:e2e",
    "test:e2e:full": "pnpm --filter iec-hub-v4 test:e2e:full",
    "test:e2e:install-browsers": "pnpm --filter iec-hub-v4 exec playwright install chromium",
    "db:seed": "pnpm --filter api db:seed:full",
    "prisma:generate": "cd apps/api && prisma generate"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@iec-hub/shared": "workspace:*",
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.6.0"
  }
}
